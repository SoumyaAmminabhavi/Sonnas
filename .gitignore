# ─────────────────────────────────────────────
#  Sonna Patisserie & Cafe — .gitignore
# ─────────────────────────────────────────────

# ── Flutter / Dart / Pub ──────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication & obfuscation
app.*.symbols
app.*.map.json

# ── Android Studio build artifacts ───────────
/android/app/debug/
/android/app/profile/
/android/app/release/

# ── Environment & Secrets ─────────────────────
# Ignore all .env files; whitelist only example/template files
.env*
!.env.example
!.env.*.example
*.secret
*.pem
*.p12
*.keystore
key.properties
android/key.properties

# ── Vercel ────────────────────────────────────
.vercel

# ── IDE & Editor ──────────────────────────────
# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code (uncomment if you don't share launch configs)
# .vscode/

# ── OS noise ──────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Miscellaneous ─────────────────────────────
*.class
*.pyc
*.swp
*.log
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
run_log.txt

# ── Node / NPM (web tooling) ──────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lib/generated/
prisma.config.js

# ── AI / Research Tooling ─────────────────────
.agents/
.cursor/
.jetro/
.mcp.json
.windsurfrules
AGENT.md
CLAUDE.md
artifacts/
data/
projects/
scratch/
issues.txt

# Local database setup
lib/services/db_migration.sql

