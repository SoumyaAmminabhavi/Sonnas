# ─────────────────────────────────────────────────────────────
#  Sonna Patisserie & Cafe — .env.server.example
# ─────────────────────────────────────────────────────────────
# Server-only secrets. NEVER bundle these in client / mobile builds.
# Use this template for backend deployments (Edge Functions, webhooks, etc.).

# Database (Supabase PostgreSQL — service role / direct connection)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres"

# WhatsApp Business API (server secrets)
WHATSAPP_TOKEN="YOUR_PERMANENT_ACCESS_TOKEN"
WHATSAPP_PHONE_ID="YOUR_PHONE_NUMBER_ID"
WHATSAPP_VERIFY_TOKEN="YOUR_WEBHOOK_VERIFY_TOKEN"

# Razorpay Payments (server secrets)
RAZORPAY_KEY_SECRET="YOUR_SECRET"
RAZORPAY_WEBHOOK_SECRET="YOUR_WEBHOOK_SECRET"

# Auth & Security
AUTH_SECRET="RANDOM_BASE64_STRING"
