generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([name])
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  posts         Post[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cake {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  image       String
  category    String       @default("General")
  isAvailable Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  options     CakeOption[]
}

model CakeOption {
  id     String @id @default(cuid())
  size   String
  serves String
  price  Int
  cakeId String
  cake   Cake   @relation(fields: [cakeId], references: [id], onDelete: Cascade)
}

model WhatsAppConversation {
  id                   String             @id @default(cuid())
  phone                String             @unique
  name                 String?
  state                String             @default("IDLE")
  selectedCake         String?
  selectedSize         String?
  selectedPrice        Int?
  selectedAddress      String?
  selectedNotes        String?
  selectedQuantity     Int?               @default(1)
  customImageUrl       String?
  selectedDeliveryDate String?
  selectedDeliveryTime String?
  messages             Json?              @default("[]")
  lastMessageAt        DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  cart                 WhatsAppCartItem[]
  orders               WhatsAppOrder[]
}

model WhatsAppCartItem {
  id           String               @id @default(cuid())
  phone        String
  cakeName     String
  size         String
  price        Int
  quantity     Int                  @default(1)
  createdAt    DateTime             @default(now())
  conversation WhatsAppConversation @relation(fields: [phone], references: [phone], onDelete: Cascade)

  @@index([phone])
}

model WhatsAppOrder {
  id              String               @id @default(cuid())
  orderNumber     String               @unique
  phone           String
  customerName    String?
  totalPrice      Int?
  address         String?
  notes           String?
  status          String               @default("PENDING")
  paymentStatus   String               @default("PENDING")
  razorpayOrderId String?
  paymentId       String?
  paymentLink     String?
  isCustom        Boolean              @default(false)
  customImageUrl  String?
  deliveryDate    String?
  deliveryTime    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  conversation    WhatsAppConversation @relation(fields: [phone], references: [phone])
  items           WhatsAppOrderItem[]

  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@index([paymentStatus])
}

model WhatsAppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model WhatsAppOrderItem {
  id       String        @id @default(cuid())
  orderId  String
  cakeName String
  size     String
  price    Int
  quantity Int           @default(1)
  order    WhatsAppOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Staff {
  id               String   @id @default(cuid())
  name             String
  phone            String   @unique
  email            String?  @unique
  imageUrl         String?
  address          String?
  dob              String?
  bloodGroup       String?
  emergencyName    String?
  emergencyPhone   String?
  role             String
  sub_role         String?  @default("NONE")
  shift            String   @default("FULL_DAY")
  permissions      Json
  shiftStart       String
  shiftEnd         String
  workingDays      Json
  password         String?
  joiningCode      String?
  isActivated      Boolean  @default(false)
  biometricEnabled Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model InventoryItem {
  id            String   @id @default(cuid())
  name          String
  category      String
  unit          String
  currentStock  Decimal  @default(0) @db.Decimal(12, 2)
  minStock      Decimal  @default(0) @db.Decimal(12, 2)
  lastRestocked DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}