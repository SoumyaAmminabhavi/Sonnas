// ─────────────────────────────────────────────────────────────────────────────
//  Sonna Patisserie — Database Schema (Prisma)
// ─────────────────────────────────────────────────────────────────────────────
//  This file defines the Supabase PostgreSQL schema using Prisma syntax.
//  It is NOT used by the Flutter app at runtime — the app connects directly
//  to Supabase via supabase_flutter. Prisma is used only for:
//    • Schema documentation and type-safe modeling
//    • Running migrations (prisma migrate dev / prisma db push)
//    • Generating a TypeScript client for any future Node.js backend
//
//  To apply schema changes:
//    1. Edit this file
//    2. Run: npm run db:migrate   (or: npx prisma migrate dev)
//    3. The migration SQL is applied to your Supabase PostgreSQL database
//
//  The Flutter app does NOT depend on Prisma at runtime.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  orders        Order[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cake {
  id          String                 @id @default(cuid())
  name        String
  slug        String                 @unique
  description String?
  image       String
  categoryId  String?
  isAvailable Boolean                @default(true)
  sortOrder   Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  category    Category?              @relation(fields: [categoryId], references: [id])
  options     CakeOption[]
  orderItems  OrderItem[]
  selectedBy  WhatsAppConversation[]

  @@index([categoryId])
  @@index([isAvailable])
  @@index([name])
}

model CakeOption {
  id          String   @id @default(cuid())
  size        String
  serves      String
  price       Int
  isAvailable Boolean  @default(true)
  cakeId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stock       Int?
  cake        Cake     @relation(fields: [cakeId], references: [id], onDelete: Cascade)

  @@unique([cakeId, size])
  @@index([cakeId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  image     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cakes     Cake[]
}

model Order {
  id              String                @id @default(cuid())
  orderNumber     String                @unique
  source          OrderSource           @default(APP)
  userId          String?
  whatsappPhone   String?
  customerName    String
  customerEmail   String?
  customerPhone   String
  totalPrice      Int
  address         String
  notes           String?
  status          OrderStatus           @default(PENDING)
  paymentStatus   PaymentStatus         @default(PENDING)
  razorpayOrderId String?
  paymentId       String?
  paymentLink     String?
  deliveryDate    DateTime?
  isCustom        Boolean               @default(false)
  customImageUrl  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  confirmedAt     DateTime?
  paidAt          DateTime?
  deliveredAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  deliverySlot    String?
  user            User?                 @relation(fields: [userId], references: [id])
  conversation    WhatsAppConversation? @relation(fields: [whatsappPhone], references: [phone], onDelete: SetNull)
  items           OrderItem[]

  @@index([userId])
  @@index([whatsappPhone])
  @@index([customerPhone])
  @@index([status])
  @@index([createdAt])
  @@index([source])
  @@index([status, createdAt])
  @@index([paymentStatus])
  @@index([deliveryDate])
  @@index([updatedAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  cakeId    String?
  cakeName  String
  size      String
  price     Int
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  cake      Cake?    @relation(fields: [cakeId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([cakeId])
}

model WhatsAppConversation {
  id                   String             @id @default(cuid())
  phone                String             @unique
  name                 String?
  state                ConversationState  @default(IDLE)
  selectedCakeId       String?
  selectedSize         String?
  selectedPrice        Int?
  selectedAddress      String?
  selectedNotes        String?
  selectedQuantity     Int?               @default(1)
  customImageUrl       String?
  selectedDeliveryDate DateTime?
  messages             Json               @default("[]")
  menuOffset           Int?               @default(0)
  lastMessageAt        DateTime           @default(now())
  lastActivityAt       DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  selectedDeliverySlot String?
  orders               Order[]
  cart                 WhatsAppCartItem[]
  selectedCake         Cake?              @relation(fields: [selectedCakeId], references: [id])

  @@index([lastActivityAt])
  @@index([selectedCakeId])
}

model WhatsAppCartItem {
  id           String               @id @default(cuid())
  phone        String
  cakeName     String
  size         String
  price        Int
  quantity     Int                  @default(1)
  createdAt    DateTime             @default(now())
  conversation WhatsAppConversation @relation(fields: [phone], references: [phone], onDelete: Cascade)

  @@index([phone])
  @@index([phone, createdAt])
}

model WhatsAppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Expense {
  id          String    @id @default(cuid())
  title       String
  amount      Decimal   @db.Decimal(12, 2)
  category    String
  date        DateTime? @default(now()) @db.Timestamptz(6)
  description String?
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([date])
  @@index([category])
}

model Staff {
  id               String    @id @default(cuid())
  name             String
  phone            String    @unique
  email            String?   @unique
  imageUrl         String?
  address          String?
  dob              String?
  bloodGroup       String?
  emergencyName    String?
  emergencyPhone   String?
  role             String
  sub_role         String?   @default("NONE")
  shift            String?   @default("FULL_DAY")
  permissions      Json      @default("{}")
  shiftStart       String
  shiftEnd         String
  workingDays      Json      @default("[]")
  password         String?
  joiningCode      String?   @unique
  isActivated      Boolean?  @default(false)
  biometricEnabled Boolean?  @default(false)
  authUserId       String?   @unique
  failedAttempts   Int       @default(0)
  lockoutUntil     DateTime? @db.Timestamptz(6)
  createdAt        DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([role])
  @@index([isActivated])
}

model InventoryItem {
  id            String    @id @default(cuid())
  name          String
  category      String
  unit          String
  currentStock  Decimal?  @default(0) @db.Decimal(12, 2)
  minStock      Decimal?  @default(0) @db.Decimal(12, 2)
  lastRestocked DateTime? @default(now()) @db.Timestamptz(6)
  createdAt     DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([category])
  @@index([currentStock])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model SystemSetting {
  key   String @id
  value String
}

enum OrderSource {
  WHATSAPP
  APP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ConversationState {
  IDLE
  START
  SELECTING_CATEGORY
  BROWSING_MENU
  SELECTING_CAKE
  SELECTING_SIZE
  ADDING_NOTES
  INPUTTING_ADDRESS
  CONFIRMING_ORDER
  CHECKOUT
  CUSTOM_ORDER_START
  CUSTOM_ORDER_IMAGE
  CUSTOM_ORDER_DETAILS
  SELECTING_QUANTITY
  ASKING_DELIVERY_DATE
}

// ==========================================
// WhatsApp Dynamic Template Engine Models
// ==========================================

model WhatsAppTemplate {
  id              String           @id @default(cuid())
  code            String // e.g. "WELCOME_MESSAGE", "CART_EMPTY"
  language        String           @default("en") // e.g. "en", "hi", "mr"
  description     String?
  category        TemplateCategory @default(GENERAL)
  isActive        Boolean          @default(true)
  activeVersionId String?          @unique // Links directly to current published version
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  versions      WhatsAppTemplateVersion[] @relation("TemplateToVersions")
  activeVersion WhatsAppTemplateVersion?  @relation("ActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  @@unique([code, language])
  @@index([code])
  @@index([isActive])
}

model WhatsAppTemplateVersion {
  id              String                  @id @default(cuid())
  templateId      String
  versionNumber   Int                     @default(1)
  bodyText        String                  @db.Text
  headerText      String?                 @db.Text
  footerText      String?                 @db.Text
  mediaUrl        String?
  mediaType       WhatsAppMediaType?
  interactiveType WhatsAppInteractiveType @default(NONE)
  ctaButtonTitle  String?
  ctaButtonUrl    String?
  listButtonTitle String?
  listTitle       String?
  changeLog       String?
  createdBy       String?
  createdAt       DateTime                @default(now())

  template     WhatsAppTemplate      @relation("TemplateToVersions", fields: [templateId], references: [id], onDelete: Cascade)
  buttons      WhatsAppButton[]
  listSections WhatsAppListSection[]
  activeFor    WhatsAppTemplate?     @relation("ActiveVersion")

  @@unique([templateId, versionNumber])
  @@index([templateId])
}

model WhatsAppButton {
  id        String @id @default(cuid())
  versionId String
  sortOrder Int    @default(0)
  buttonId  String
  title     String

  version WhatsAppTemplateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
}

model WhatsAppListSection {
  id         String            @id @default(cuid())
  versionId  String
  sortOrder  Int               @default(0)
  title      String
  dataSource SectionDataSource @default(STATIC)

  rows    WhatsAppListRow[]
  version WhatsAppTemplateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
}

model WhatsAppListRow {
  id          String  @id @default(cuid())
  sectionId   String
  sortOrder   Int     @default(0)
  rowId       String
  title       String
  description String?

  section WhatsAppListSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

// ==========================================
// Enums for WhatsApp Template System
// ==========================================

enum TemplateCategory {
  GREETING
  MENU
  CATEGORY
  PRODUCT
  ORDER
  PAYMENT
  DELIVERY
  ERROR
  GENERAL
}

enum WhatsAppMediaType {
  IMAGE
  VIDEO
  DOCUMENT
  NONE
}

enum WhatsAppInteractiveType {
  NONE
  BUTTONS
  LIST
  CTA_URL
}

enum SectionDataSource {
  STATIC
  CATEGORIES
  TOP_FAVORITES
  PRODUCT_LIST
  CURRENT_CART
  ACTIVE_ORDERS
}
