# ─────────────────────────────────────────────────────────────
#  Sonna Patisserie & Cafe — .env.client.example
# ─────────────────────────────────────────────────────────────
# Client-safe environment variables only.
# Use this template for front-end / mobile builds.
# NEVER include server-only secrets in client artifacts.

# Supabase Keys (public anon key is safe for client)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# Aliases for compatibility
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# WhatsApp (public-facing only)
NEXT_PUBLIC_WHATSAPP_NUMBER=91...
NEXT_PUBLIC_WHATSAPP_NUMBER_FORMATTED=+91 ...

# Razorpay (public key only)
RAZORPAY_KEY_ID=rzp_test_...
