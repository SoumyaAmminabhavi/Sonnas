generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  orders        Order[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cake {
  id          String                 @id @default(cuid())
  name        String
  slug        String                 @unique
  description String?
  image       String
  categoryId  String?
  isAvailable Boolean                @default(true)
  sortOrder   Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  category    Category?              @relation(fields: [categoryId], references: [id])
  options     CakeOption[]
  orderItems  OrderItem[]
  selectedBy  WhatsAppConversation[]

  @@index([categoryId])
  @@index([isAvailable])
  @@index([name])
}

model CakeOption {
  id          String   @id @default(cuid())
  size        String
  serves      String
  price       Int
  isAvailable Boolean  @default(true)
  cakeId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stock       Int?
  cake        Cake     @relation(fields: [cakeId], references: [id], onDelete: Cascade)

  @@unique([cakeId, size])
  @@index([cakeId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  image     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cakes     Cake[]
}

model Order {
  id              String                @id @default(cuid())
  orderNumber     String                @unique
  source          OrderSource           @default(APP)
  userId          String?
  whatsappPhone   String?
  customerName    String
  customerEmail   String?
  customerPhone   String
  totalPrice      Int
  address         String
  notes           String?
  status          OrderStatus           @default(PENDING)
  paymentStatus   PaymentStatus         @default(PENDING)
  razorpayOrderId String?
  paymentId       String?
  paymentLink     String?
  deliveryDate    DateTime?
  isCustom        Boolean               @default(false)
  customImageUrl  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  confirmedAt     DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  deliverySlot    String?
  user            User?                 @relation(fields: [userId], references: [id])
  conversation    WhatsAppConversation? @relation(fields: [whatsappPhone], references: [phone], onDelete: Cascade)
  items           OrderItem[]

  @@index([customerPhone])
  @@index([status])
  @@index([createdAt])
  @@index([source])
  @@index([status, createdAt])
  @@index([paymentStatus])
  @@index([deliveryDate])
  @@index([updatedAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  cakeId    String?
  cakeName  String
  size      String
  price     Int
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  cake      Cake?    @relation(fields: [cakeId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model WhatsAppConversation {
  id                   String             @id @default(cuid())
  phone                String             @unique
  name                 String?
  state                ConversationState  @default(IDLE)
  selectedCakeId       String?
  selectedSize         String?
  selectedPrice        Int?
  selectedAddress      String?
  selectedNotes        String?
  selectedQuantity     Int?               @default(1)
  customImageUrl       String?
  selectedDeliveryDate DateTime?
  messages             Json               @default("[]")
  menuOffset           Int?               @default(0)
  lastMessageAt        DateTime           @default(now())
  lastActivityAt       DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  selectedDeliverySlot String?
  orders               Order[]
  cart                 WhatsAppCartItem[]
  selectedCake         Cake?              @relation(fields: [selectedCakeId], references: [id])

  @@index([lastActivityAt])
  @@index([selectedCakeId])
}

model WhatsAppCartItem {
  id           String               @id @default(cuid())
  phone        String
  cakeName     String
  size         String
  price        Int
  quantity     Int                  @default(1)
  createdAt    DateTime             @default(now())
  conversation WhatsAppConversation @relation(fields: [phone], references: [phone], onDelete: Cascade)

  @@index([phone])
  @@index([phone, createdAt])
}

model WhatsAppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Expense {
  id          String    @id @default(cuid())
  title       String
  amount      Decimal   @db.Decimal(12, 2)
  category    String
  date        DateTime? @default(now()) @db.Timestamptz(6)
  description String?
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
}

model Staff {
  id               String    @id @default(cuid())
  name             String
  phone            String    @unique
  email            String?   @unique
  imageUrl         String?
  address          String?
  dob              String?
  bloodGroup       String?
  emergencyName    String?
  emergencyPhone   String?
  role             String
  sub_role         String?   @default("NONE")
  shift            String?   @default("FULL_DAY")
  permissions      Json      @default("{}")
  shiftStart       String
  shiftEnd         String
  workingDays      Json      @default("[]")
  password         String?
  joiningCode      String?
  isActivated      Boolean?  @default(false)
  biometricEnabled Boolean?  @default(false)
  createdAt        DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
}

model InventoryItem {
  id            String    @id @default(cuid())
  name          String
  category      String
  unit          String
  currentStock  Decimal?  @default(0) @db.Decimal(12, 2)
  minStock      Decimal?  @default(0) @db.Decimal(12, 2)
  lastRestocked DateTime? @default(now()) @db.Timestamptz(6)
  createdAt     DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model SystemSetting {
  key   String @id
  value String
}

enum OrderSource {
  WHATSAPP
  APP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ConversationState {
  IDLE
  START
  SELECTING_CATEGORY
  BROWSING_MENU
  SELECTING_CAKE
  SELECTING_SIZE
  ADDING_NOTES
  INPUTTING_ADDRESS
  CONFIRMING_ORDER
  CHECKOUT
  CUSTOM_ORDER_START
  CUSTOM_ORDER_IMAGE
  CUSTOM_ORDER_DETAILS
  SELECTING_QUANTITY
  ASKING_DELIVERY_DATE
}
