// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    posts         Post[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model Cake {
    id          String       @id @default(cuid())
    name        String
    description String?
    image       String
    category    String       @default("General")
    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt
    
    options     CakeOption[]
}

model CakeOption {
    id        String   @id @default(cuid())
    size      String
    serves    String
    price     String
    
    cakeId    String
    cake      Cake     @relation(fields: [cakeId], references: [id], onDelete: Cascade)
}

// ─── WhatsApp Automation ────────────────────────────────────────────────────

model WhatsAppConversation {
    id             String   @id @default(cuid())
    phone          String   @unique
    name           String?
    state          String   @default("IDLE")
    selectedCake   String?
    selectedSize   String?
    selectedPrice  String?
    selectedAddress String?
    selectedNotes    String?
    selectedQuantity Int?     @default(1)
    
    customImageUrl   String?
    selectedDeliveryDate String?
    selectedDeliveryTime String?
    messages         Json?    @default("[]")
    
    lastMessageAt  DateTime @default(now())
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    cart           WhatsAppCartItem[]
    orders         WhatsAppOrder[]
}

model WhatsAppCartItem {
    id             String   @id @default(cuid())
    phone          String
    cakeName       String
    size           String
    price          String
    quantity       Int      @default(1)
    createdAt      DateTime @default(now())
    
    conversation   WhatsAppConversation @relation(fields: [phone], references: [phone], onDelete: Cascade)

    @@index([phone])
}

model WhatsAppOrder {
    id             String   @id @default(cuid())
    orderNumber    String   @unique
    phone          String
    customerName   String?
    
    totalPrice     String?
    address        String?
    notes        String?
    status       String   @default("PENDING")
    paymentStatus  String   @default("PENDING")
    razorpayOrderId String?
    paymentId      String?
    paymentLink    String?
    
    isCustom     Boolean  @default(false)
    customImageUrl String?
    
    deliveryDate   String?
    deliveryTime   String?
    paymentReminderSent Boolean @default(false)
    
    createdAt    DateTime @default(now())
    updatedAt      DateTime @updatedAt

    items          WhatsAppOrderItem[]
    conversation   WhatsAppConversation @relation(fields: [phone], references: [phone])

    @@index([phone])
    @@index([status])
    @@index([createdAt])
    @@index([paymentStatus])
}

model WhatsAppOrderItem {
    id             String   @id @default(cuid())
    orderId        String
    cakeName       String
    size           String
    price          String
    quantity       Int      @default(1)
    
    order          WhatsAppOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
