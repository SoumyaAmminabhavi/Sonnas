# ─────────────────────────────────────────────────────────────
#  Sonna Patisserie & Cafe — Root .env.example
# ─────────────────────────────────────────────────────────────
# This is a template file for setting up local environment variables.
# Copy this file to '.env' in the root directory and fill in the values.
# NEVER commit the real '.env' file containing secrets to version control!

# ── Database Connection ───────────────────────────────────────
# Get from Supabase -> Project Settings -> Database.
# Use Direct Connection (Port 5432) for running migrations, and connection pooler (Port 6543) for the Next.js app.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# ── Supabase Keys (Public & Client) ───────────────────────────
# Get from Supabase -> Project Settings -> API.
# Flutter mobile/desktop app client variables:
SUPABASE_URL="https://[REF].supabase.co"
SUPABASE_ANON_KEY="your_anon_key_here"

# Next.js web application aliases (for client side hydration):
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key_here"

# ── WhatsApp Business API ────────────────────────────────────
# Next.js Server-side integration keys:
WHATSAPP_TOKEN="your_whatsapp_system_user_token"
WHATSAPP_PHONE_ID="your_phone_number_id"
WHATSAPP_VERIFY_TOKEN="your_custom_verify_token"

# Publicly visible WhatsApp variables:
NEXT_PUBLIC_WHATSAPP_NUMBER="91..."
NEXT_PUBLIC_WHATSAPP_NUMBER_FORMATTED="+91XXXXXXXXXX"

# ── Razorpay Payments ─────────────────────────────────────────
# Keys obtained from Razorpay dashboard:
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_secret_here"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret_here"

# ── NextAuth & Administration Security ───────────────────────
# A random secret key used for securing cookies and session tokens in NextAuth:
AUTH_SECRET="your_random_auth_secret_at_least_32_chars"
