# ─────────────────────────────────────────────────────────────
#  Sonna Patisserie & Cafe — .env.example
# ─────────────────────────────────────────────────────────────
# This is a template file. Copy it to '.env' and fill in the values.
# NEVER commit the real '.env' file to version control.

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres"

# Supabase Keys
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_PUBLIC_KEY"

# Aliases for compatibility
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_PUBLIC_KEY"

# WhatsApp Business API
WHATSAPP_TOKEN="YOUR_PERMANENT_ACCESS_TOKEN"
WHATSAPP_PHONE_ID="YOUR_PHONE_NUMBER_ID"
WHATSAPP_VERIFY_TOKEN="YOUR_WEBHOOK_VERIFY_TOKEN"
NEXT_PUBLIC_WHATSAPP_NUMBER="91..."
NEXT_PUBLIC_WHATSAPP_NUMBER_FORMATTED="+91 ..."

# Razorpay Payments
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="YOUR_SECRET"
RAZORPAY_WEBHOOK_SECRET="YOUR_WEBHOOK_SECRET"

# Auth & Security
AUTH_SECRET="RANDOM_BASE64_STRING"
