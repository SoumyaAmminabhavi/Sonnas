# Database (Get from Supabase -> Project Settings -> Database)
# Use the Direct Connection (Port 5432) for migrations, and Pooler (Port 6543) for the app.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# Supabase Keys (Get from Supabase -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key_here"

# WhatsApp Business API Keys
WHATSAPP_TOKEN="your_whatsapp_system_user_token"
WHATSAPP_PHONE_ID="your_phone_number_id"
WHATSAPP_VERIFY_TOKEN="your_custom_verify_token"
NEXT_PUBLIC_WHATSAPP_NUMBER="91..."
NEXT_PUBLIC_WHATSAPP_NUMBER_FORMATTED="+91 ..."

# Razorpay Integration
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_secret_here"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret_here"

# Automation & Security
# Used for NextAuth / Admin Dashboard security
AUTH_SECRET="your_random_auth_secret_at_least_32_chars"
